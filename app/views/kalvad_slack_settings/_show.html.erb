<% setting = KalvadSlackSetting.for(@project) %>

<%= labelled_form_for :kalvad_slack_setting,
                       setting,
                       url: project_kalvad_slack_setting_path(@project),
                       html: { method: :put, id: 'kalvad-slack-setting-form' } do |f| %>
  <div class="box tabular">
    <p>
      <%= f.text_field :webhook_url, size: 80,
                       label: :setting_kalvad_slack_webhook_url %>
    </p>
    <p>
      <%= f.text_field :channel, size: 40,
                       label: :setting_kalvad_slack_channel %>
      <em class="info"><%= l(:text_kalvad_slack_channel_required) %></em>
    </p>
    <p>
      <%= f.text_field :username, size: 40,
                       label: :setting_kalvad_slack_username %>
    </p>
    <p>
      <%= f.text_field :icon, size: 40,
                       label: :setting_kalvad_slack_icon %>
      <em class="info"><%= l(:text_kalvad_slack_icon_help) %></em>
    </p>
  </div>

  <fieldset class="box tabular">
    <legend><%= l(:label_kalvad_slack_toggles) %></legend>
    <% KalvadSlackSetting::BOOL_FIELDS.each do |field| %>
      <p>
        <label for="kalvad_slack_setting_<%= field %>">
          <%= l(:"setting_kalvad_slack_#{field}") %>
        </label>
        <%= hidden_field_tag "kalvad_slack_setting[#{field}]", '0' %>
        <%= check_box_tag "kalvad_slack_setting[#{field}]", '1', setting.public_send(field),
                          id: "kalvad_slack_setting_#{field}" %>
      </p>
    <% end %>
  </fieldset>

  <p><%= submit_tag l(:button_save) %></p>
<% end %>
